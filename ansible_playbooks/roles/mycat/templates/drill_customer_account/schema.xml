<?xml version="1.0"?>
<!DOCTYPE mycat:schema SYSTEM "schema.dtd">
<mycat:schema xmlns:mycat="http://io.mycat/">
        <schema name="account" checkSQLschema="false" sqlMaxLimit="100">
                <table name="MYCAT_SEQUENCE"  primaryKey="name" dataNode="dn1" />
                <table name="charge_order" primaryKey="record_id" autoIncrement="true" dataNode="dn$1-12" rule="mod-by-member_id" />
                <table name="member_account_pwd" primaryKey="record_id" dataNode="dn$1-12" rule="mod-by-member_id" />
                <table name="member_account_pwd_record" primaryKey="record_id" dataNode="dn$1-12" rule="mod-by-member_id" />
                <table name="denomination_manager" primaryKey="record_id" dataNode="dn$1-12"  type="global" />
        </schema>
        <dataNode name="dn$1-12" dataHost="account1" database="account_db$1-12" />
        <dataHost name="account1" maxCon="1000" minCon="10" balance="0" writeType="0" dbType="mysql" dbDriver="native" switchType="1"  slaveThreshold="100">
                <heartbeat>select user()</heartbeat>
                <writeHost host="hostM1" url="{{ drill_customer_account_write_host_url }}:" user="{{ drill_customer_account_write_host_user }}" password="{{ drill_customer_account_write_host_password }}">
                        <readHost host="hostS2" url="{{ drill_customer_account_read_host_url }}" user="{{ drill_customer_account_read_host_user }}" password="{{ drill_customer_account_read_host_password }}" />
                </writeHost>
        </dataHost>
</mycat:schema>

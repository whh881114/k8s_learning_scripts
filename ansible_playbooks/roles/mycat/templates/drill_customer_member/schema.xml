<?xml version="1.0"?>
<!DOCTYPE mycat:schema SYSTEM "schema.dtd">
<mycat:schema xmlns:mycat="http://io.mycat/">
        <schema name="member" checkSQLschema="false" sqlMaxLimit="100">
        <table name="MYCAT_SEQUENCE" primaryKey="name" dataNode="dn1" />

        <!--基础会员-->
        <table name="basic_member" primaryKey="memberNum" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="basic_member_ext" primaryKey="memberNum" dataNode="dn$1-12" rule="mod-by-memberNum"/>

        <!--维度会员-->
        <table name="member" primaryKey="memberId" dataNode="dn$1-12" rule="mod-by-memberId"/>
        <table name="member_update_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_verify_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_transfer_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_cancel_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_lock_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_login_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_operate_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_level_modify_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_growth_value" primaryKey="memberNum" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_growth_value_modify_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_equity_receive_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_code_key" primaryKey="memberId" dataNode="dn$1-12" rule="mod-by-memberId"/>
        <table name="month_gift_push_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="member_level_msg_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>

        <!--付费会员-->
                <table name="pay_member_type" primaryKey="typeCode" type="global" dataNode="dn$1-12"/>
        <table name="pay_member_redeem_code_batch" primaryKey="batchCode" dataNode="dn$1-12" type="global" />
        <table name="pay_member_redeem_code_detail" primaryKey="recordId" dataNode="dn$1-12" type="global" />
        <table name="pay_member" primaryKey="memberNum" dataNode="dn$1-12" rule="mod-by-memberNum"/>
                <table name="pay_member_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum" />
                <table name="pay_member_detail" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="pay_member_modify_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="pay_member_refund_record" primaryKey="refundNum" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="pay_member_save_money_detail" primaryKey="recordId" autoIncrement="true" dataNode="dn$1-12" rule="mod-by-memberNum"/>
        <table name="pay_member_expire_notify_record" primaryKey="recordId" dataNode="dn$1-12" rule="mod-by-memberNum"/>

        <table name="black_white_list" primaryKey="listId" dataNode="dn1"/>
        <table name="member_level" primaryKey="levelId" dataNode="dn$1-12" type="global" />
        <table name="member_equity" primaryKey="equityCode" dataNode="dn$1-12" type="global" />
        <table name="member_equity_level" primaryKey="recordId" dataNode="dn$1-12" type="global" />
        <table name="member_equity_identity_level" primaryKey="recordId" dataNode="dn$1-12" type="global" />
        <table name="member_level_task" primaryKey="recordId" dataNode="dn$1-12" type="global" />
        <table name="member_level_task_detail" primaryKey="recordId" dataNode="dn$1-12" type="global" />

        <table name="pay_member_update" primaryKey="memberNum" dataNode="dn$1-12" rule="mod-by-memberNum"/>

        <table name="member_external_list" primaryKey="recordId" dataNode="dn1" type="global" />
        <table name="member_external_priority" primaryKey="recordId" dataNode="dn1" type="global" />
        </schema>

        <dataNode name="dn$1-12" dataHost="member1" database="member_db$1-12" />

        <dataHost name="member1" maxCon="3000" minCon="10" balance="1" writeType="0" dbType="mysql" dbDriver="native" switchType="1"  slaveThreshold="100">
                <heartbeat>select user()</heartbeat>
                <writeHost host="hostM1" url="{{ drill_customer_member_write_host_url }}" user="{{ drill_customer_member_write_host_user }}" password="{{ drill_customer_member_write_host_password }}">
                        <readHost host="hostS2" url="{{ drill_customer_member_read_host_url }}" user="{{ drill_customer_member_read_host_user }}" password="{{ drill_customer_member_read_host_password }}" />
                </writeHost>
        </dataHost>
</mycat:schema>
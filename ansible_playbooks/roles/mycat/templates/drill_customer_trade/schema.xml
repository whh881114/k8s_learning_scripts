<?xml version="1.0"?>
<!DOCTYPE mycat:schema SYSTEM "schema.dtd">
<mycat:schema xmlns:mycat="http://io.mycat/">
	<schema name="trade" checkSQLschema="false" sqlMaxLimit="100">
		<table name="trade_order" primaryKey="trade_id" dataNode="dn$1-12" rule="mod-by-trade_id" />
		<table name="trade_order_detail" primaryKey="detail_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
		<table name="payment_order" primaryKey="payment_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
		<table name="trade_charge_order" primaryKey="order_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
		<table name="activity" primaryKey="activity_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
        <table name="activity_detail" primaryKey="detail_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>

		<table name="cost_order" primaryKey="cost_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
        <table name="body_apportion_detail" primaryKey="apportion_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
        <table name="goods_apportion_detail" primaryKey="goods_cost_detail_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
        <table name="refund_order" primaryKey="refund_id"  dataNode="dn$1-12" rule="mod-by-trade_id"/>
        <table name="refund_detail" primaryKey="detail_id"  dataNode="dn$1-12" rule="mod-by-trade_id"/>
        <table name="refund_goods_detail" primaryKey="detail_id" dataNode="dn$1-12" rule="mod-by-trade_id"/>
	</schema>
	<dataNode name="dn$1-12" dataHost="trade1" database="trade_db$1-12" />
	<dataHost name="trade1" maxCon="1000" minCon="10" balance="0" writeType="0" dbType="mysql" dbDriver="native" switchType="1"  slaveThreshold="100">
		<heartbeat>select user()</heartbeat>
		<writeHost host="hostM1" url="{{ drill_customer_trade_write_host_url }}" user="{{ drill_customer_trade_write_host_user }}" password="{{ drill_customer_trade_write_host_password }}">
			<readHost host="hostS2" url="{{ drill_customer_trade_read_host_url }}" user="{{ drill_customer_trade_read_host_user }}" password="{{ drill_customer_trade_read_host_password }}" />
		</writeHost>
	</dataHost>
</mycat:schema>

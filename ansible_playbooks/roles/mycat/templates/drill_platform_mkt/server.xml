<!DOCTYPE mycat:server SYSTEM "server.dtd">
<mycat:server xmlns:mycat="http://io.mycat/">
        <system>

    <property name="defaultSqlParser">druidparser</property>
    <property name="serverPort">28066</property>
    <property name="managerPort">29066</property>
    <property name="useGlobleTableCheck">0</property>
    <property name="useOffHeapForMerge">0</property> <!-- 0为关闭堆外处理-->
        <property name="useSqlStat">0</property>  <!-- 1为开启实时统计、0为关闭 -->
    <property name="processorBufferChunk">40960</property>
    <property name="processors">32</property>

        <property name="sequnceHandlerType">2</property>

        </system>

        <!-- 全局SQL防火墙设置 -->
        <!--白名单可以使用通配符%或着*-->
        <!--例如<host host="127.0.0.*" user="root"/>-->
        <!--例如<host host="127.0.*" user="root"/>-->
        <!--例如<host host="127.*" user="root"/>-->
        <!--例如<host host="1*7.*" user="root"/>-->
        <!--这些配置情况下对于127.0.0.1都能以root账户登录-->
        <!--
        <firewall>
           <whitehost>
              <host host="1*7.0.0.*" user="root"/>
           </whitehost>
       <blacklist check="false">
       </blacklist>
        </firewall>
        -->

        <user name="marketing" defaultAccount="true">
                <property name="password">mkt@act#2019!10</property>
                <property name="schemas">marketing_drill_mycat</property>

                <!-- 表级 DML 权限设置 -->
                <!--
                <privileges check="false">
                        <schema name="TESTDB" dml="0110" >
                                <table name="tb01" dml="0000"></table>
                                <table name="tb02" dml="1111"></table>
                        </schema>
                </privileges>
                 -->
        </user>

        <user name="{{ drill_platform_mkt_user }}">
                <property name="password">{{ drill_platform_mkt_password }}</property>
                <property name="schemas">marketing_drill_mycat</property>
                <property name="readOnly">true</property>
        </user>

</mycat:server>
$TTL 1D
redis.example.com.   IN    SOA     dns01.redis.example.com. root.lb.example.com. (
                0       ; serial
                1D      ; refresh
                1H      ; retry
                1W      ; expire
                3H )    ; minimum

                    IN      NS      dns01.redis.example.com.
dns01               IN      A       192.168.255.252

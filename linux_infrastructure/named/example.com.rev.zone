$TTL 1D
@       IN      SOA     example.com     root.example.com. (
                        0       ; serial
                        1D      ; refresh
                        1H      ; retry
                        1W      ; expire
                        3H )    ; minimum
        IN      NS      ns.example.com.  
252     IN      PTR     ns.example.com.
252     IN      PTR     foreman.example.com.
